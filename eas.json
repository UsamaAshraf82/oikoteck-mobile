{
  "cli": {
    "version": ">= 16.17.4",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_APP_VARIANT": "development"
      },
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview"
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_APP_VARIANT": "production"
      },
      "channel": "production"
    },
    "production-android": {
      "extends": "production",
      "env": {
        "ENABLE_IAP": "false"
      }
    },

    "production-ios": {
      "extends": "production",
      "env": {
        "ENABLE_IAP": "true"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6738630038",
        "appleId": "usamaashraf28@gmail.com",
        "appleTeamId": "NCF3Q9455Q",
        "sku": "com.oikoteck.app"
      }
    },
    "production-ios": {
      "ios": {
        "ascAppId": "6738630038",
        "appleId": "usamaashraf28@gmail.com",
        "appleTeamId": "NCF3Q9455Q",
        "sku": "com.oikoteck.app"
      }
    }
  }
}
